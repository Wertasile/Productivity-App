@using System.Globalization
@inject ItemService ItemService

@if (IsVisible)
{
    <div class="cd-backdrop" @onclick="Cancel"></div>

    <div class="cd-panel" role="dialog" aria-modal="true" aria-labelledby="er-title">
        <div class="d-flex justify-content-between align-items-center">
            <h2 id="er-title">Edit Reminder</h2>
            <button @onclick="Cancel" aria-label="Close">
                <Blazicon Svg="Lucide.X" />
            </button>
        </div>

        <div class="d-flex flex-column gap-6">
            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="cd-error" role="alert">@errorMessage</div>
            }

            <div class="cd-form">
                <div class="cd-field">
                    <label for="er-name">Name <span class="cd-required">*</span></label>
                    <input id="er-name" type="text" placeholder="Reminder name" @bind="editModel.Name"
                           @bind:event="oninput" />
                </div>

                <div class="cd-field">
                    <label for="er-desc">Description</label>
                    <textarea id="er-desc" placeholder="Optional description" rows="4" @bind="editModel.Description"
                              @bind:event="oninput"></textarea>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <input id="er-acknowledged" type="checkbox" style="width: auto; padding: 0;"
                           @bind="editModel.IsAcknowledged" />
                    <label for="er-acknowledged" style="margin: 0;">Acknowledged</label>
                </div>

                <div class="cd-field">
                    <label for="er-datetime">Reminder date & time</label>
                    <input id="er-datetime" type="datetime-local" value="@reminderDateTimeInput"
                           @onchange="e => reminderDateTimeInput = FormatDateTimeLocalValue(e.Value)" />
                </div>

                <div class="cd-field">
                    <label for="er-priority">Priority</label>
                    <select id="er-priority" @bind="editModel.Priority">
                        @foreach (var option in PriorityOptions)
                        {
                            <option value="@option.Value">@option.Label</option>
                        }
                    </select>
                </div>
            </div>

            <div class="cd-footer d-flex justify-content-between align-items-center">
                <button style="color: #C53030;" @onclick="DeleteAsync" disabled="@isSubmitting"><Blazicon Svg="Lucide.Trash" /></button>
                <div class="d-flex gap-2">
                    <button class="secondary-btn" @onclick="Cancel" disabled="@isSubmitting">Cancel</button>
                    <button class="primary-btn" @onclick="SubmitAsync" disabled="@isSubmitting">
                        @(isSubmitting ? "Saving…" : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public Reminder Reminder { get; set; } = new();
    [Parameter] public EventCallback<bool> OnClose { get; set; }

    private readonly Reminder editModel = new();
    private string reminderDateTimeInput = string.Empty;
    private bool isSubmitting;
    private string? errorMessage;
    private string _lastId = string.Empty;

    protected override void OnParametersSet()
    {
        if (!IsVisible)
        {
            _lastId = string.Empty;
            return;
        }

        var currentId = Reminder.Id ?? string.Empty;
        if (currentId == _lastId) return;

        _lastId = currentId;
        errorMessage = null;

        editModel.Id = Reminder.Id;
        editModel.UserId = Reminder.UserId;
        editModel.Name = Reminder.Name;
        editModel.Description = Reminder.Description;
        editModel.IsAcknowledged = Reminder.IsAcknowledged;
        editModel.ReminderDateTime = Reminder.ReminderDateTime;
        editModel.Priority = Math.Clamp(Reminder.Priority, 0, 3);
        editModel.EntityType = Reminder.EntityType;
        editModel.CreatedAt = Reminder.CreatedAt;
        editModel.UpdatedAt = Reminder.UpdatedAt;

        reminderDateTimeInput = ToDateTimeLocalValue(editModel.ReminderDateTime);
    }

    private async Task SubmitAsync()
    {
        if (isSubmitting) return;

        if (string.IsNullOrWhiteSpace(editModel.Name))
        {
            errorMessage = "Reminder name is required.";
            return;
        }

        errorMessage = null;

        try
        {
            isSubmitting = true;

            if (!TryParseDateTimeLocal(reminderDateTimeInput, out var reminderDateTime))
            {
                errorMessage = "Reminder date and time is required.";
                return;
            }

            editModel.ReminderDateTime = reminderDateTime;
            editModel.Priority = Math.Clamp(editModel.Priority, 0, 3);
            editModel.UpdatedAt = DateTime.UtcNow;

            var updatedItem = await ItemService.UpdateItemAsync(editModel);

            if (updatedItem is null)
            {
                errorMessage = "The reminder could not be updated.";
                return;
            }

            await OnClose.InvokeAsync(true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteAsync()
    {
        if (isSubmitting) return;

        try
        {
            isSubmitting = true;
            await ItemService.DeleteItemAsync(editModel.Id);
            await OnClose.InvokeAsync(true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task Cancel() => await OnClose.InvokeAsync(false);

    private static bool TryParseDateTimeLocal(string? value, out DateTime parsed)
    {
        parsed = default;
        if (string.IsNullOrWhiteSpace(value)) return false;
        if (DateTime.TryParseExact(value, DateTimeLocalFormats,
                CultureInfo.InvariantCulture, DateTimeStyles.None, out parsed))
            return true;
        return DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out parsed);
    }

    private static string FormatDateTimeLocalValue(object? value)
    {
        if (value is DateTime dateTime)
            return dateTime == default ? string.Empty : dateTime.ToString("yyyy-MM-ddTHH:mm");

        var stringValue = value?.ToString();
        return string.IsNullOrWhiteSpace(stringValue) ? string.Empty : stringValue;
    }

    private static string ToDateTimeLocalValue(DateTime value)
        => value == default ? string.Empty : value.ToString("yyyy-MM-ddTHH:mm");

    private static readonly string[] DateTimeLocalFormats =
    {
        "yyyy-MM-ddTHH:mm",
        "yyyy-MM-ddTHH:mm:ss",
        "yyyy-MM-ddTHH:mm:ss.fff"
    };

    private static readonly (int Value, string Label)[] PriorityOptions =
    {
        (0, "No Priority"),
        (1, "Low Priority (Green)"),
        (2, "Medium Priority (Yellow)"),
        (3, "High Priority (Red)")
    };
}
