@page "/"
@page "/login"
@using ActualBlazorStandAloneAppSPA.Components
@inject TokenStore TokenStore
@inject AppSessionService AppSessionService
@inject NavigationManager Navigation

<div class="auth-page">

    <!-- Left branding panel -->
    <div class="auth-brand-panel">
        <div class="auth-brand-content">
            <h1 class="auth-brand-name">ProdPadre</h1>
            <p class="auth-brand-tagline">Your thoughts, beautifully organized. Capture ideas, manage tasks, and stay on top of everything — all in one place.</p>
        </div>
        <div>
            <p class="auth-brand-footer">© @DateTime.Now.Year ProdPadre</p>
        </div>
        <div class="auth-brand-dots">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-form-panel">
        @if (authState == AuthState.Login)
        {
            <LoginForm OnSwitch="SetState" />
        }
        else if (authState == AuthState.Register)
        {
            <RegisterForm OnSwitch="SetState" OnEmailCaptured="SetPendingEmail" />
        }
        else if (authState == AuthState.ConfirmEmail)
        {
            <ConfirmEmailForm OnSwitch="SetState" Email="@pendingEmail" />
        }
        else if (authState == AuthState.ForgotPassword)
        {
            <ForgotPasswordForm OnSwitch="SetState" OnEmailCaptured="SetPendingEmail" />
        }
        else if (authState == AuthState.ResetPassword)
        {
            <ResetPasswordForm OnSwitch="SetState" Email="@pendingEmail" />
        }
    </div>

</div>

@code {
    [SupplyParameterFromQuery(Name = "mode")]
    private string? Mode { get; set; }

    private AuthState authState = AuthState.Login;
    private string? pendingEmail;

    private void SetState(AuthState state) => authState = state;
    private void SetPendingEmail(string email) => pendingEmail = email;

    protected override async Task OnInitializedAsync()
    {
        var guestSession = await AppSessionService.GetGuestSessionAsync();
        var tokens = await TokenStore.GetTokensAsync();
        var forceSignIn = string.Equals(Mode, "signin", StringComparison.OrdinalIgnoreCase);

        if (!forceSignIn && (guestSession is not null || tokens is not null))
        {
            Navigation.NavigateTo("/dashboard");
        }
    }
}

