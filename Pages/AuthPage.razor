@page "/"
@page "/login"
@using ActualBlazorStandAloneAppSPA.Components
@inject TokenStore TokenStore
@inject AppSessionService AppSessionService
@inject NavigationManager Navigation

@if (authState == AuthState.Login)
{
   <LoginForm OnSwitch="setState"/>
}
else if (authState == AuthState.Register)
{
    <RegisterForm OnSwitch="setState"/>
}
else if (authState == AuthState.ConfirmEmail)
{
    <ConfirmEmailForm OnSwitch="setState"/>
}

@code {
    [SupplyParameterFromQuery(Name = "mode")]
    private string? Mode { get; set; }

    // AuthState is an enum that represents the current state of the authentication process (Login, Register, ConfirmEmail)
    // It has been declared in Enums Folder and is in Imports.razor for easy access across the application
    private AuthState authState = AuthState.Login;

    private void setState(AuthState state)
    {
        authState = state;
    }

    protected override async Task OnInitializedAsync()
    {
        var guestSession = await AppSessionService.GetGuestSessionAsync();
        var tokens = await TokenStore.GetTokensAsync();
        var forceSignIn = string.Equals(Mode, "signin", StringComparison.OrdinalIgnoreCase);

        if (!forceSignIn && (guestSession is not null || tokens is not null))
        {
            Navigation.NavigateTo("/dashboard");
        }
    }
}
