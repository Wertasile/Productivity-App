@page "/calendar"
@using Microsoft.AspNetCore.Authorization
@layout MainLayout
@attribute [Authorize]
@using System.Text.Json
@inject HttpClient Http
@inject IDialogService DialogService
@inject CalendarService CalendarService

<PageTitle>Calendar</PageTitle>

<div class="calendar-page">
    <section class="calendar-panel">
        <div class="calendar-panel-header">
            <div class="calendar-heading-block">
                <div class="eyebrow">Editorial Planner</div>
                <div class="calendar-heading">
                    <h1>@CurrentMonth.ToString("MMMM")</h1>
                    <span>@CurrentMonth.Year</span>
                </div>
            </div>

            <div class="calendar-controls">
                <button class="icon-button" @onclick="PrevMonthAsync" aria-label="Previous month">&#8249;</button>
                <button class="icon-button" @onclick="NextMonthAsync" aria-label="Next month">&#8250;</button>
            </div>
        </div>

        <div class="calendar-filters">
            <span class="chip chip-task"><span class="chip-dot"></span>Tasks</span>
            <span class="chip chip-reminder"><span class="chip-dot"></span>Reminders</span>
            <span class="chip chip-note"><span class="chip-dot"></span>Notes</span>
            <span class="chip chip-project"><span class="chip-dot"></span>Monthly Focus</span>
        </div>

        <div class="calendar-board">
            <div class="calendar-grid">
                @foreach (var day in DayHeaders)
                {
                    <div class="weekday">@day</div>
                }

                @foreach (var day in GenerateCalendarDays())
                {
                    var key = day.ToString("yyyy-MM-dd");
                    var isCurrentMonth = day.Month == CurrentMonth.Month;
                    var isToday = day.Date == DateTime.Today;
                    calendarResponse.TryGetValue(key, out var item);
                    var allEntries = GetDayEntries(item);
                    var entries = allEntries.Take(3).ToList();
                    var extraCount = Math.Max(0, allEntries.Count - entries.Count);

                    <div class="date-cell @(isCurrentMonth ? "" : "date-cell-muted") @(isToday ? "date-cell-today" : "")"
                         @onclick="() => OpenCreateDateDialogAsync(day)">
                        <div class="date-cell-header">
                            <span class="date-number">@day.Day</span>
                            @if (isToday)
                            {
                                <span class="today-pill">Today</span>
                            }
                        </div>

                        <div class="date-event-list">
                            @foreach (var entry in entries)
                            {
                                @if (entry.OnClick is not null)
                                {
                                    <button class="event-pill @entry.CssClass"
                                            @onclick="entry.OnClick"
                                            @onclick:stopPropagation="true"
                                            title="@entry.Subtitle">
                                        @entry.Title
                                    </button>
                                }
                                else
                                {
                                    <span class="event-pill @entry.CssClass" title="@entry.Subtitle">@entry.Title</span>
                                }
                            }

                            @if (extraCount > 0)
                            {
                                <span class="event-pill event-pill-more">+@extraCount more</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="feed-panel">
        <div class="feed-header">
            <div>
                <div class="eyebrow">Curated Notes</div>
                <h2>Monthly Feed</h2>
            </div>
        </div>

        <div class="feed-list">
            @foreach (var feedDay in GetFeedDays())
            {
                <div class="feed-day">
                    <div class="feed-day-header">
                        <span class="feed-date">@feedDay.Day.ToString("dd")</span>
                        <span class="feed-rule"></span>
                        <span class="feed-weekday">@feedDay.Day.ToString("dddd").ToUpperInvariant()</span>
                    </div>

                    <div class="feed-items">
                        @foreach (var entry in feedDay.Entries)
                        {
                            <div class="feed-item @entry.CssClass">
                                <div class="feed-item-icon"></div>
                                <div class="feed-item-copy">
                                    @if (entry.OnClick is not null)
                                    {
                                        <button class="feed-item-button"
                                                @onclick="entry.OnClick">
                                            @entry.Title
                                        </button>
                                    }
                                    else
                                    {
                                        <h3>@entry.Title</h3>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(entry.Subtitle))
                                    {
                                        <p>@entry.Subtitle</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </section>
</div>

@code {
    public DateTime CurrentMonth = DateTime.Now;
    private CalendarResponse calendarResponse = new();

    public List<string> DayHeaders = new() { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" };

    protected override async Task OnInitializedAsync()
    {
        await LoadCalendarAsync();
    }

    private async Task OpenCreateDateDialogAsync(DateTime selectedDate)
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var parameters = new DialogParameters
        {
            { "SelectedDate", selectedDate.Date }
        };

        var dialog = await DialogService.ShowAsync<CreateCalendarItemDialog>(
            $"Add item for {selectedDate:dd MMM}",
            parameters,
            options);

        var result = await dialog.Result;

        if (result is null || result.Canceled || result.Data is not BaseItem)
        {
            return;
        }

        await LoadCalendarAsync();
    }

    private async Task LoadCalendarAsync()
    {
        try
        {
            calendarResponse = await CalendarService.GetMonthAsync(CurrentMonth);
        }
        catch (Exception)
        {
            calendarResponse = await Http.GetFromJsonAsync<CalendarResponse>("sample-data/SampleCalendarResponse.json")
                ?? new CalendarResponse();
        }
    }

    private async Task OpenTaskAsync(TaskItem task)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters
        {
            { "Task", task }
        };

        var dialog = await DialogService.ShowAsync<EditTaskDialog>("Edit Task", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadCalendarAsync();
        }
    }

    private async Task OpenReminderAsync(Reminder reminder)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters
        {
            { "Reminder", reminder }
        };

        var dialog = await DialogService.ShowAsync<EditReminderDialog>("Edit Reminder", parameters, options);
        var result = await dialog.Result;

        if (result is not null && !result.Canceled)
        {
            await LoadCalendarAsync();
        }
    }

    public async Task PrevMonthAsync()
    {
        CurrentMonth = CurrentMonth.AddMonths(-1);
        await LoadCalendarAsync();
    }

    public async Task NextMonthAsync()
    {
        CurrentMonth = CurrentMonth.AddMonths(1);
        await LoadCalendarAsync();
    }

    public List<DateTime> GenerateCalendarDays()
    {
        var days = new List<DateTime>();
        var firstDayOfMonth = new DateTime(CurrentMonth.Year, CurrentMonth.Month, 1);
        var diff = (7 + (firstDayOfMonth.DayOfWeek - DayOfWeek.Sunday)) % 7;
        var startDate = firstDayOfMonth.AddDays(-diff);

        for (var i = 0; i < 42; i++)
        {
            days.Add(startDate.AddDays(i));
        }

        return days;
    }

    private List<CalendarEntryViewModel> GetDayEntries(CalendarItem? item)
    {
        var entries = new List<CalendarEntryViewModel>();

        if (item is null)
        {
            return entries;
        }

        entries.AddRange(item.Tasks.Select(task => new CalendarEntryViewModel(
            task.Title,
            string.IsNullOrWhiteSpace(task.Description) ? $"Due {task.DueDate:h:mm tt}" : task.Description,
            "event-pill-task",
            () => OpenTaskAsync(task))));

        entries.AddRange(item.Reminders.Select(reminder => new CalendarEntryViewModel(
            reminder.Name,
            string.IsNullOrWhiteSpace(reminder.Description) ? $"Reminder at {reminder.ReminderDate:h:mm tt}" : reminder.Description,
            "event-pill-reminder",
            () => OpenReminderAsync(reminder))));

        entries.AddRange(item.Notes.Select(note => new CalendarEntryViewModel(
            note.Title,
            GetNotePreview(note.Content),
            "event-pill-note",
            null)));

        return entries;
    }

    private IEnumerable<FeedDayViewModel> GetFeedDays()
    {
        return Enumerable.Range(1, DateTime.DaysInMonth(CurrentMonth.Year, CurrentMonth.Month))
            .Select(day => new DateTime(CurrentMonth.Year, CurrentMonth.Month, day))
            .Select(date => new FeedDayViewModel(date, GetDayEntries(calendarResponse.GetValueOrDefault(date.ToString("yyyy-MM-dd")))))
            .Where(feedDay => feedDay.Entries.Count > 0)
            .Take(6);
    }

    private static string GetNotePreview(string? content)
    {
        if (string.IsNullOrWhiteSpace(content))
        {
            return "Open note";
        }

        const int maxLength = 82;
        return content.Length <= maxLength ? content : $"{content[..maxLength].Trim()}...";
    }

    private sealed record CalendarEntryViewModel(string Title, string Subtitle, string CssClass, Func<Task>? OnClick);

    private sealed record FeedDayViewModel(DateTime Day, List<CalendarEntryViewModel> Entries);
}
