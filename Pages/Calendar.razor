@page "/calendar"
@using Microsoft.AspNetCore.Authorization
@layout MainLayout
@attribute [Authorize]
@using System.Text.Json
@inject HttpClient Http
@inject IDialogService DialogService
@inject CalendarService CalendarService
@inject ItemService ItemService

<PageTitle>Calendar</PageTitle>

<div class="calendar-page">
    <section class="calendar-panel">
        <div class="d-flex justify-content-between ">
            <div class="d-flex gap-1 align-items-center">
                <h1>@CurrentMonth.ToString("MMMM") </h1>
                <div class="sub-header"> | @CurrentMonth.Year</div>
            </div>

            <div class="d-flex gap-1">
                <button class="icon-button" @onclick="PrevMonthAsync" aria-label="Previous month">&#8249;</button>
                <button class="icon-button" @onclick="NextMonthAsync" aria-label="Next month">&#8250;</button>
            </div>
        </div>

        <div class="d-flex gap-2 align-items-center">
            <span class="chip chip-task"><span class="chip-dot"></span>Tasks</span>
            <span class="chip chip-phase-task"><span class="chip-dot"></span>Project Task</span>
            <span class="chip chip-reminder"><span class="chip-dot"></span>Reminders</span>
            <span class="chip chip-note"><span class="chip-dot"></span>Notes</span>
        </div>

        <div class="calendar-board">
            <div class="calendar-grid">
                @foreach (var day in DayHeaders)
                {
                    <div class="weekday">@day</div>
                }

                @foreach (var day in GenerateCalendarDays())
                {
                    var key = day.ToString("yyyy-MM-dd");
                    var isCurrentMonth = day.Month == CurrentMonth.Month; @* GENERATE CURRENT MONTH*@
                    var isToday = day.Date == DateTime.Today;
                    calendarResponse.TryGetValue(key, out var item);

                    var allEntries = GetDayEntries(day, item);
                    var entries = allEntries.Take(3).ToList();
                    var extraCount = Math.Max(0, allEntries.Count - entries.Count);


                    <div class="date-cell @(isCurrentMonth ? "" : "date-cell-muted") @(isToday ? "date-cell-today" : "")"
                         @onclick="() => OpenCreateDateDialogAsync(day)">
                        <div class="date-cell-header">
                            @if (isToday)
                            {
                                <span class="today-pill">@day.Day</span>
                            }
                            else
                            {
                                <span class="date-number">@day.Day</span>
                            }
                        </div>

                        <div class="date-event-list" @ondragover:preventDefault="true"
                             @ondrop="() => OnEntryDroppedAsync(day)">
                            @foreach (var entry in entries)
                            {
                                @if (entry.OnClick is not null)
                                {
                                    <button class="event-pill @entry.CssClass" draggable="true"
                                            @ondragstart="() => OnDragStart(entry)" @onclick="entry.OnClick"
                                            @onclick:stopPropagation="true" title="@entry.Subtitle">
                                        @entry.Title
                                    </button>
                                }
                                else
                                {
                                    <span class="event-pill @entry.CssClass" title="@entry.Subtitle">@entry.Title</span>
                                }
                            }

                            @if (extraCount > 0)
                            {
                                <span class="event-pill event-pill-more">+@extraCount more</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="feed-panel">
        <h2>Monthly Feed</h2>
        <div class="feed-list">
            @foreach (var feedDay in GetFeedDays())
            {
                <div class="d-flex flex-column gap-3">
                    <div class="feed-day-header">
                        <h3>@feedDay.Day.ToString("dd")</h3>
                        <span class="feed-rule"></span>
                        <span class="lil-text">@feedDay.Day.ToString("dddd").ToUpperInvariant()</span>
                    </div>

                    <div class="d-flex flex-column gap-2">
                        @foreach (var entry in feedDay.Entries)
                        {
                            <div class="feed-item" style="cursor:@(entry.OnClick is not null ? "pointer" : "default");"
                                 @onclick="@(entry.OnClick ?? (() => Task.CompletedTask))">
                                <div>
                                    @if (entry.Type == "TASK")
                                    {
                                        <Blazicon Svg="Lucide.Check" style="font-size:150%; color:#504BEF" />
                                    }
                                    else if (entry.Type == "REMINDER")
                                    {
                                        <Blazicon Svg="Lucide.Bell" style="font-size:150%; color:#F67ADF" />
                                    }
                                </div>
                                <div class="flex flex-column gap-1">
                                    <div class="sub-header">@entry.Title</div>
                                    @if (!string.IsNullOrWhiteSpace(entry.Subtitle))
                                    {
                                        <p>@entry.Subtitle</p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </section>
</div>

<CreateCalendarItemDialog IsVisible="@createDialogVisible" SelectedDate="@createDialogDate"
                          OnClose="OnCreateDialogClosedAsync" />

<EditTaskDialog IsVisible="@editTaskVisible" Task="@currentEditTask" OnClose="OnEditTaskClosedAsync" />

<EditReminderDialog IsVisible="@editReminderVisible" Reminder="@currentEditReminder"
                    OnClose="OnEditReminderClosedAsync" />

@code {
    public DateTime CurrentMonth = DateTime.Now;
    private CalendarResponse calendarResponse = new();

    private int monthOffset = 0;
    private bool createDialogVisible;
    private DateTime createDialogDate;

    private bool editTaskVisible;
    private TaskItem currentEditTask = new();
    private bool editReminderVisible;
    private Reminder currentEditReminder = new();
    private List<TaskItem> monthTasks = new();

    public List<string> DayHeaders = new() { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" };

    private DraggedCalendarItem? draggedItem;

    protected override async Task OnInitializedAsync()
    {
        await LoadCalendarAsync();
    }

    private async Task LoadCalendarAsync()
    {
        try
        {
            calendarResponse = await CalendarService.GetMonthAsync(CurrentMonth, monthOffset);
            monthTasks = calendarResponse
                .SelectMany(kv => kv.Value.Tasks)
                .Where(task => !string.IsNullOrWhiteSpace(task.Id))
                .GroupBy(task => task.Id)
                .Select(group => group.First())
                .ToList();

            Console.WriteLine($"[Calendar] Response has {calendarResponse.Count} day entries.");

            var totalTasks = calendarResponse.Sum(kv => kv.Value.Tasks.Count);
            var totalReminders = calendarResponse.Sum(kv => kv.Value.Reminders.Count);
            Console.WriteLine($"[Calendar] Totals → Tasks: {totalTasks}, Reminders: {totalReminders}");

            // Dictionary enumeration order is not meaningful here, so sample non-empty days first.
            foreach (var kv in calendarResponse
                         .Where(kv => kv.Value.Tasks.Count > 0 || kv.Value.Reminders.Count > 0)
                         .Take(5))
            {
                Console.WriteLine($"[Calendar] Non-empty '{kv.Key}' → Tasks: {kv.Value.Tasks.Count}, Reminders: {kv.Value.Reminders.Count}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Calendar] Error loading: {ex.GetType().Name}: {ex.Message}");
        }
    }

    private void OnCreateDialogClosedAsync()
    {
        createDialogVisible = false;
    }

    private void OpenCreateDateDialogAsync(DateTime selectedDate)
    {
        createDialogDate = selectedDate.Date;
        createDialogVisible = true;
    }

    private async Task OnCreateDialogClosedAsync(BaseItem? result)
    {
        createDialogVisible = false;

        if (result is not null)
        {
            await LoadCalendarAsync();
        }
    }

    private Task OpenTaskAsync(TaskItem task)
    {
        currentEditTask = task;
        editTaskVisible = true;
        return Task.CompletedTask;
    }

    private Task OpenReminderAsync(Reminder reminder)
    {
        currentEditReminder = reminder;
        editReminderVisible = true;
        return Task.CompletedTask;
    }

    private async Task OnEditTaskClosedAsync(bool success)
    {
        editTaskVisible = false;
        if (success) await LoadCalendarAsync();
    }

    private async Task OnEditReminderClosedAsync(bool success)
    {
        editReminderVisible = false;
        if (success) await LoadCalendarAsync();
    }

    public async Task PrevMonthAsync()
    {
        CurrentMonth = CurrentMonth.AddMonths(-1);
        monthOffset--;
        await LoadCalendarAsync();
    }

    public async Task NextMonthAsync()
    {
        CurrentMonth = CurrentMonth.AddMonths(1);
        monthOffset++;
        await LoadCalendarAsync();
    }

    public List<DateTime> GenerateCalendarDays()
    {
        var days = new List<DateTime>();
        var firstDayOfMonth = new DateTime(CurrentMonth.Year, CurrentMonth.Month, 1);
        var diff = (7 + (firstDayOfMonth.DayOfWeek - DayOfWeek.Sunday)) % 7;
        var startDate = firstDayOfMonth.AddDays(-diff);

        for (var i = 0; i < 42; i++)
        {
            days.Add(startDate.AddDays(i));
        }

        return days;
    }

    private List<CalendarEntryViewModel> GetDayEntries(DateTime day, CalendarItem? item)
    {
        var entries = new List<CalendarEntryViewModel>();

        var dayTasks = monthTasks
            .Where(task => DoesTaskSpanDate(task, day))
            .ToList();

        if (item is not null)
        {
            // Keep day-specific tasks from API even when Start/End is missing.
            foreach (var task in item.Tasks)
            {
                if (dayTasks.All(x => x.Id != task.Id))
                {
                    dayTasks.Add(task);
                }
            }
        }

        entries.AddRange(dayTasks.Select(task =>
        {
            var (start, end) = GetTaskRange(task);

            var displayTime =
                $"{start:h:mm tt}-{end:h:mm tt}";

            var subtitle = string.IsNullOrWhiteSpace(task.Description)
                ? $"{task.Status} • {GetPriorityLabel(task.Priority)} • {displayTime}"
                : task.Description;

            return new CalendarEntryViewModel(
                task.Id,
                "TASK",
                task.Title,
                subtitle,
                "event-pill-task",
                start,
                () => OpenTaskAsync(task)
            );
        }));

        if (item is not null)
        {
            entries.AddRange(item.Reminders.Select(reminder =>
            {
                var reminderTime =
                    reminder.ReminderDateTime != default
                        ? reminder.ReminderDateTime
                        : DateTime.Now;

                var subtitle = string.IsNullOrWhiteSpace(reminder.Description)
                    ? $"{GetPriorityLabel(reminder.Priority)} • Reminder at {reminderTime:h:mm tt}"
                    : reminder.Description;

                return new CalendarEntryViewModel(
                    reminder.Id,
                    "REMINDER",
                    reminder.Name,
                    subtitle,
                    "event-pill-reminder",
                    reminderTime,
                    () => OpenReminderAsync(reminder)
                );
            }));
        }

        return entries;
    }

    private IEnumerable<FeedDayViewModel> GetFeedDays()
    {
        return Enumerable.Range(1, DateTime.DaysInMonth(CurrentMonth.Year, CurrentMonth.Month))
            .Select(day => new DateTime(CurrentMonth.Year, CurrentMonth.Month, day))
            .Select(date => new FeedDayViewModel(date, GetDayEntries(date,
calendarResponse.GetValueOrDefault(date.ToString("yyyy-MM-dd")))))
            .Where(feedDay => feedDay.Entries.Count > 0)
            .Take(10);
    }

    private static (DateTime Start, DateTime End) GetTaskRange(TaskItem task)
    {
        var start = task.Start != default ? task.Start : task.End;
        var end = task.End != default ? task.End : task.Start;

        if (start == default && end == default)
        {
            start = DateTime.Today;
            end = DateTime.Today;
        }

        if (end < start)
        {
            (start, end) = (end, start);
        }

        return (start, end);
    }

    private static bool DoesTaskSpanDate(TaskItem task, DateTime day)
    {
        var (start, end) = GetTaskRange(task);
        return day.Date >= start.Date && day.Date <= end.Date;
    }

    private Task OnDragStart(CalendarEntryViewModel entry)
    {
        draggedItem = new DraggedCalendarItem
        {
            Id = entry.Id,
            Type = entry.Type,
            OriginalDate = entry.Date
        };

        return Task.CompletedTask;
    }

    private async Task OnEntryDroppedAsync(DateTime targetDate)
    {
        if (draggedItem is null)
        {
            return;
        }

        var source = draggedItem;
        draggedItem = null;

        var original = source.OriginalDate;

        var newDateTime = new DateTime(
            targetDate.Year,
            targetDate.Month,
            targetDate.Day,
            original.Hour,
            original.Minute,
            original.Second
        );

        BaseItem? updatedItem = null;

        if (source.Type == "TASK")
        {
            var task = calendarResponse
                .SelectMany(x => x.Value.Tasks)
                .FirstOrDefault(t => t.Id == source.Id);

            if (task is null) return;

            var duration = task.End - task.Start;
            if (duration <= TimeSpan.Zero)
            {
                duration = TimeSpan.FromHours(1);
            }

            var newStart = newDateTime;
            var newEnd = newStart.Add(duration);

            updatedItem = new TaskItem
            {
                Id = task.Id,
                UserId = task.UserId,
                parentTaskId = task.parentTaskId,
                Title = task.Title,
                Description = task.Description,
                Progress = task.Progress,
                Priority = task.Priority,
                Status = task.Status,
                CompletionDate = task.CompletionDate,
                Start = newStart,
                End = newEnd,
                CreatedAt = task.CreatedAt,
                UpdatedAt = DateTime.UtcNow,
                EntityType = task.EntityType
            };
        }
        else if (source.Type == "REMINDER")
        {
            var reminder = calendarResponse
                .SelectMany(x => x.Value.Reminders)
                .FirstOrDefault(r => r.Id == source.Id);

            if (reminder is null) return;

            updatedItem = new Reminder
            {
                Id = reminder.Id,
                UserId = reminder.UserId,
                Name = reminder.Name,
                Description = reminder.Description,
                IsAcknowledged = reminder.IsAcknowledged,
                Priority = reminder.Priority,
                ReminderDateTime = newDateTime,
                CreatedAt = reminder.CreatedAt,
                UpdatedAt = DateTime.UtcNow,
                EntityType = reminder.EntityType
            };
        }

        if (updatedItem is not null)
        {
            await ItemService.UpdateItemAsync(updatedItem);
            await LoadCalendarAsync();
        }
    }

    private static string GetNotePreview(string? content)
    {
        if (string.IsNullOrWhiteSpace(content))
        {
            return "Open note";
        }

        const int maxLength = 82;
        return content.Length <= maxLength ? content : $"{content[..maxLength].Trim()}...";
    }

    private static string GetPriorityLabel(int priority)
    {
        return Math.Clamp(priority, 0, 3) switch
        {
            1 => "Low Priority",
            2 => "Medium Priority",
            3 => "High Priority",
            _ => "No Priority"
        };
    }

    private sealed record CalendarEntryViewModel(
        string Id,
        string Type,
        string Title,
        string Subtitle,
        string CssClass,
        DateTime Date,
        Func<Task>? OnClick
    );

    public class DraggedCalendarItem
    {
        public string Id { get; set; } = string.Empty;
        public string Type { get; set; } = string.Empty; // "TASK" or "REMINDER"
        public DateTime OriginalDate { get; set; }
    }

    private sealed record FeedDayViewModel(DateTime Day, List<CalendarEntryViewModel> Entries);
}
