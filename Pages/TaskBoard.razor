    public int GetWeekOfMonth()
    {
        // get todays date and use it to get first day of month
        var firstDayOfMonth = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);

        // calculate the week of month based on the first day of month and todays date
        int offset = (int)firstDayOfMonth.DayOfWeek; // returns an enumerated value where Sunday = 0, Monday = 1, ...,Saturday = 6, therefore needs to be typecast to int

        int weekOfMonth = ((DateTime.Now.Day + offset - 1) / 7) + 1;

        return weekOfMonth;
    }

