@page "/taskboard"
@using Microsoft.AspNetCore.Authorization
@layout MainLayout
@attribute [Authorize]
@inject TaskBoardService taskBoardService
@using System.Text.Json
@inject IDialogService DialogService

<div class="d-flex justify-content-between">
    <h2>TASKBOARD!</h2>
    <div>
        <div class="btn primary-green-btn">ADD ITEM</div>
        <div class="btn secondary-green-btn">CALENDAR</div>
    </div>
</div>

<div>
    <h3>WEEK @currentWeekOfMonth, @(DateTime.Now.ToString("MMMM")) @DateTime.Now.Year</h3>
</div>

<div>
    FROM @weekData?.WeekStart.ToString("dd MMMM") TO @weekData?.WeekEnd.ToString("dd MMMM")
</div>

<div class="d-flex flex-column gap-6">

    <div class="day-header-wrapper">
        <div class="time-col"></div>
        @foreach (var day in Days)
        {
            <div class="day-header">
                @day.ToUpper()
                <h4>@DateTime.Now.AddDays(((int)Enum.Parse<DayOfWeek>(day, true) - (int)DateTime.Now.DayOfWeek + 7) % 7).ToString("dd")</h4>
            </div>
        }
    </div>

    <div class="d-flex gap-4 flex-column">
        @for (int hour = 0; hour < 24; hour++)
        {
            <div class="time-row">
                <div class="time-col">@($"{hour}:00")</div>

                @foreach (var day in Days)
                {
                    <div class="calendar-cell">
                        @if (Schedule.ContainsKey((Enum.Parse<DayOfWeek>(day, true), hour)))
                        {
                            @foreach (var item in Schedule[(Enum.Parse<DayOfWeek>(day, true), hour)])
                            {
                                if (item is TaskItem task)
                                {
                                    <div class="event eventTask" @onclick="() => OpenTaskAsync(task)">
                                        <div>@task.Title</div>
                                        <div>@task.Progress %</div>
                                        <div>@task.Status</div>
                                        <div style="color:@GetPriorityColor(task.Priority)">@GetPriorityLabel(task.Priority)</div>
                                    </div>
                                }
                                else if (item is Reminder reminder)
                                {
                                    <div class="event eventReminder" @onclick="() => OpenReminderAsync(reminder)">
                                        <div>@reminder.Name</div>
                                        <div style="color:@GetPriorityColor(reminder.Priority)">@GetPriorityLabel(reminder.Priority)</div>
                                    </div>
                                }
                            }
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private TaskBoardResponse? weekData;
    private int currentWeekOfMonth;

    public List<string> Days = new()
    {
        "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"
    };

    private Dictionary<(DayOfWeek, int), List<BaseItem>> Schedule = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTaskBoardAsync();
    }

    private async Task OpenTaskAsync(TaskItem task)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters
        {
            { "Task", task }
        };

        var dialog = await DialogService.ShowAsync<EditTaskDialog>("Edit Task", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadTaskBoardAsync();
        }
    }

    private async Task OpenReminderAsync(Reminder reminder)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters
        {
            { "Reminder", reminder }
        };

        var dialog = await DialogService.ShowAsync<EditReminderDialog>("Edit Reminder", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadTaskBoardAsync();
        }
    }

    private async Task LoadTaskBoardAsync()
    {
        weekData = await taskBoardService.GetTaskBoardAsync();

        var serialisedWeekData = JsonSerializer.Serialize(weekData, new JsonSerializerOptions
        {
            WriteIndented = true
        });

        Console.WriteLine(serialisedWeekData);

        MapEvents();
        currentWeekOfMonth = GetWeekOfMonth();
    }

    public void MapEvents()
    {
        Schedule.Clear();

        if (weekData?.Items is null)
        {
            return;
        }

        foreach (var item in weekData.Items)
        {
            foreach (var dateItem in item.Value.Tasks)
            {
                AddEvent(dateItem.Start, dateItem);
            }

            foreach (var dateItem in item.Value.Reminders)
            {
                AddEvent(dateItem.ReminderDateTime, dateItem);
            }
        }
    }

    public void AddEvent(DateTime dateTime, BaseItem theEvent)
    {
        var key = (dateTime.DayOfWeek, dateTime.Hour);
        if (!Schedule.ContainsKey(key))
        {
            Schedule[key] = new List<BaseItem>();
        }

        Schedule[key].Add(theEvent);
    }

    public int GetWeekOfMonth()
    {
        var firstDayOfMonth = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
        int offset = (int)firstDayOfMonth.DayOfWeek;
        int weekOfMonth = ((DateTime.Now.Day + offset - 1) / 7) + 1;

        return weekOfMonth;
    }

    private static string GetPriorityLabel(int priority)
    {
        return Math.Clamp(priority, 0, 3) switch
        {
            1 => "Low Priority",
            2 => "Medium Priority",
            3 => "High Priority",
            _ => "No Priority"
        };
    }

    private static string GetPriorityColor(int priority)
    {
        return Math.Clamp(priority, 0, 3) switch
        {
            1 => "#2F855A",
            2 => "#D69E2E",
            3 => "#C53030",
            _ => "#718096"
        };
    }
}
