    public void AddEvent(DateTime dateTime, BaseItem theEvent, string EntityType)
    {
        var key = (dateTime.DayOfWeek, dateTime.Hour);
        if (!Schedule.ContainsKey(key))
        {
            Schedule[key] = new List<BaseItem>();
        }
        Schedule[key].Add(theEvent);
    }

