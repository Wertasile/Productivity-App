@page "/taskboard"
@using Microsoft.AspNetCore.Authorization
@layout MainLayout
@attribute [Authorize]
@inject TaskBoardService taskBoardService
@inject IJSRuntime JS
@inject HttpClient Http
@using System.Text.Json
@inject IDialogService DialogService


<div class="d-flex justify-content-between">
    <h2>TASKBOARD!</h2>
    <div>
        <div class="btn primary-green-btn">ADD ITEM</div>
        <div class="btn secondary-green-btn">CALENDAR</div>
    </div>
</div>

<div>
    <h3>WEEK @currentWeekOfMonth, @(DateTime.Now.ToString("MMMM")) 2025</h3>
</div>

<div>
    FROM @weekData?.WeekStart.ToString("dd MMMM") TO @weekData?.WeekEnd.ToString("dd MMMM")
</div>

    <div class="d-flex flex-column gap-6">

    @* ROW 1 *@
        <div class="day-header-wrapper">
            <div class="time-col"></div>
            @foreach (var day in Days)
            {
                <div class="day-header">
                    @day.ToUpper()
                    <h4>@DateTime.Now.AddDays(((int)Enum.Parse<DayOfWeek>(day, true) - (int)DateTime.Now.DayOfWeek + 7) %
                                                                                                    7).ToString("dd")</h4>
                </div>
            }
        </div>

        <div class="d-flex gap-4 flex-column">
            @for (int hour = 0; hour < 24; hour++)
            {
                <div class="time-row">
                    <div class="time-col">@($"{hour}:00")</div>

                    @foreach (var day in Days)
                    {
                        <div class="calendar-cell">
                            @* @RenderEvents(day, hour) *@

                            @* key is (Enum.Parse<DayOfWeek>(day, true), hour) // convert day string to DayOfWeek enum, ignoring case sensitivity *@
                            @* key is (Sunday, 4) i.e. (Day, hour). The day itself is represented by a number*@
                            @if (Schedule.ContainsKey((Enum.Parse<DayOfWeek>(day, true), hour)))
                            {
                                @foreach (var item in Schedule[(Enum.Parse<DayOfWeek>(day, true), hour)])
                                {
                                    if (item is TaskItem task)
                                    {
                                        <div class="event eventTask" @onclick="(e) => OpenTaskAsync(task)">
                                            <div>@task.Title</div>
                                            <div>@task.Progress %</div>
                                        </div>
                                    }
                                    else if (item is Reminder reminder)
                                    {
                                        <div class="event eventReminder" @onclick="(e) => OpenReminderAsync(reminder)">
                                            @reminder.Name
                                        </div>
                                    }
                                }
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
@code {

    TaskBoardResponse? weekData;

    int currentWeekOfMonth;

    public List<String> Days = new List<string>() { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday",
"Saturday" };

    Dictionary<(DayOfWeek, int), List<BaseItem>> Schedule = new();

    private Task OpenTaskAsync(TaskItem task)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters
        {
            { "Task", task }
        };
        return DialogService.ShowAsync<EditTaskDialog>("Edit Task", parameters, options);
    }

    private Task OpenReminderAsync(Reminder reminder)
    {
        var options = new DialogOptions { CloseOnEscapeKey = true };
        var parameters = new DialogParameters
        {
            { "Reminder", reminder }
        };
        return DialogService.ShowAsync<EditReminderDialog>("Edit Reminder", parameters, options);
    }

