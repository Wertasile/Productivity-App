@using System.Security.Claims
@using Blazicons
@using Microsoft.AspNetCore.Components.Authorization
@using MudBlazor
@inject AuthService AuthService
@inject IDialogService DialogService
@inject NavigationManager Navigation

<aside
    class="sidebar-shell @(sidebarCollapsed ? "sidebar-shell--collapsed" : "") d-flex flex-column justify-content-between">
    <div class="sidebar-top">
        <div class="sidebar-header">
            <button type="button" class="sidebar-toggle-btn" @onclick="ToggleSidebar"
                    aria-label="@(sidebarCollapsed ? "Expand navigation" : "Collapse navigation")"
                    title="@(sidebarCollapsed ? "Expand navigation" : "Collapse navigation")">
                <Blazicon Svg="@SidebarToggleIcon" />
            </button>
            <h2 class="sidebar-label">ProdPadre</h2>
        </div>


        <div class="d-flex flex-column gap-2">
            <div class="d-flex gap-2 justify-content-center">
                <button type="button"
                        class="icon-btn-task icon-btn"
                        aria-label="Create task"
                        title="Create task"
                        @onclick='() => OpenCreateDialogAsync("task")'>
                        <div style="font-size: 150%;">
                            <Blazicon Svg="Lucide.AlarmClockPlus" />
                        </div>
                </button>

                <button type="button"
                        class="icon-btn-reminder icon-btn"
                        style="@(sidebarCollapsed ? "display: none;" : "")"
                        aria-label="Create reminder"
                        title="Create reminder"
                        @onclick='() => OpenCreateDialogAsync("reminder")'>
                        <div style="font-size: 150%;">
                            <Blazicon Svg="Lucide.BellPlus" />
                        </div>
                </button>
            </div>
            <div>
                <button type="button" class="@(sidebarCollapsed ? "icon-btn icon-btn-primary" : "primary-btn")" style="@(sidebarCollapsed ? "width: 48px; min-width: 0;" : "width: 100%;")" @onclick="OpenNewNote">
                    + <span class="text">New Note</span>
                </button>
            </div>
        </div>

        <nav class="sidebar-nav" aria-label="Primary">
            <a href="/dashboard" class="sidebar-nav-link @(selectedPage == "Home" ? "fw-bold" : "")"
               Match="NavLinkMatch.All" @onclick='() => SelectPage("Home")'>
                <span class="sidebar-nav-icon" aria-hidden="true">
                    <Blazicon Svg="Lucide.House" />
                </span>
                <span class="sidebar-label">Home</span>
            </a>

            <a href="/journal" class="sidebar-nav-link @(selectedPage == "Journal" ? "fw-bold" : "")"
               @onclick='() => SelectPage("Journal")'>
                <span class="sidebar-nav-icon" aria-hidden="true">
                    <Blazicon Svg="Lucide.BookOpen" />
                </span>
                <span class="sidebar-label">Journal</span>
            </a>

            <a href="/calendar" class="sidebar-nav-link @(selectedPage == "Calendar" ? "fw-bold" : "")"
               @onclick='() => SelectPage("Calendar")'>
                <span class="sidebar-nav-icon" aria-hidden="true">
                    <Blazicon Svg="Lucide.Calendar" />
                </span>
                <span class="sidebar-label">Calendar</span>
            </a>

            <a href="/library" class="sidebar-nav-link @(selectedPage == "Library" ? "fw-bold" : "")"
               @onclick='() => SelectPage("Library")'>
                <span class="sidebar-nav-icon" aria-hidden="true">
                    <Blazicon Svg="Lucide.Folder" />
                </span>
                <span class="sidebar-label">Library</span>
            </a>

            <a href="/projects" class="sidebar-nav-link @(selectedPage == "Project" ? "fw-bold" : "")"
               @onclick='() => SelectPage("Project")'>
                <span class="sidebar-nav-icon" aria-hidden="true">
                    <Blazicon Svg="Lucide.Layers" />
                </span>
                <span class="sidebar-label">Projects</span>
            </a>

            <a href="/habits" class="sidebar-nav-link @(selectedPage == "Habits" ? "fw-bold" : "")"
               @onclick='() => SelectPage("Habits")'>
                <span class="sidebar-nav-icon" aria-hidden="true">
                    <Blazicon Svg="Lucide.Dumbbell" />
                </span>
                <span class="sidebar-label">Habits</span>
            </a>

            <a href="/payments" class="sidebar-nav-link @(selectedPage == "Payments" ? "fw-bold" : "")"
               @onclick='() => SelectPage("Payments")'>
                <span class="sidebar-nav-icon" aria-hidden="true">
                    <Blazicon Svg="Lucide.CreditCard" />
                </span>
                <span class="sidebar-label">Payments</span>
            </a>

            <a href="/settings" class="sidebar-nav-link @(selectedPage == "Settings" ? "fw-bold" : "")"
               @onclick='() => SelectPage("Settings")'>
                <span class="sidebar-nav-icon" aria-hidden="true">
                    <Blazicon Svg="Lucide.Settings" />
                </span>
                <span class="sidebar-label">Settings</span>
            </a>
        </nav>
    </div>
    <div class="sidebar-footer">
        <div class="sidebar-nav-link sidebar-session-btn" @onclick="HandleSessionActionAsync"
                aria-label="@sessionActionLabel" title="@sessionActionLabel">
            @if (showSignIn)
            {
                <span class="sidebar-nav-icon" aria-hidden="true">
                    <Blazicon Svg="Lucide.LogIn" />
                </span>
            }
            else
            {
                <span class="sidebar-nav-icon" aria-hidden="true">
                    <Blazicon Svg="Lucide.LogOut" />
                </span>
            }
            <span class="sidebar-label">@sessionActionLabel</span>
        </div>

        @* <div class="sidebar-account-card">
            <div class="profile-avatar">@profileInitials</div>
            <div class="profile-copy">
                <div class="profile-name">@profileName</div>
                <div class="profile-role">@profileMeta</div>
            </div>
        </div> *@
    </div>
</aside>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private bool sidebarCollapsed;
    private bool isGuestMode;
    private bool isAuthenticated;
    private string selectedPage = "Home";
    private string profileName = "Guest Account";
    private string profileMeta = "LOCAL SESSION";
    private string profileInitials = "G";

    private bool showSignIn => isGuestMode || !isAuthenticated;
    private string sessionActionLabel => showSignIn ? "Sign In" : "Sign Out";
    private Blazicons.SvgIcon SidebarToggleIcon => sidebarCollapsed ? Lucide.ChevronRight : Lucide.ChevronLeft;

    protected override async Task OnParametersSetAsync()
    {
        var authState = AuthenticationStateTask is null
            ? new AuthenticationState(new ClaimsPrincipal(new ClaimsIdentity()))
            : await AuthenticationStateTask;

        var user = authState.User;

        isAuthenticated = user.Identity?.IsAuthenticated == true;
        isGuestMode = string.Equals(user.FindFirst("auth_mode")?.Value, "guest", StringComparison.OrdinalIgnoreCase);

        if (showSignIn)
        {
            profileName = "Local Account";
            profileMeta = "LOCAL SESSION";
            profileInitials = "L";
            return;
        }

        var email =
            user.FindFirst(ClaimTypes.Email)?.Value ??
            user.FindFirst("email")?.Value;

        profileName = email ?? "Account";
        profileMeta = "SIGNED IN";
        profileInitials = GetInitials(email ?? "Account");
    }

    private void ToggleSidebar()
    {
        sidebarCollapsed = !sidebarCollapsed;
    }

    private void SelectPage(string page)
    {
        selectedPage = page;
    }

    private async Task OpenCreateDialogAsync(string initialType)
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var parameters = new DialogParameters
        {
            { "SelectedDate", DateTime.Today },
            { "InitialType", initialType }
        };

        await DialogService.ShowAsync<CreateCalendarItemDialog>("Create item", parameters, options);
    }

    private void OpenNewNote()
    {
        Navigation.NavigateTo("/add-note");
    }

    private async Task HandleSessionActionAsync()
    {
        if (showSignIn)
        {
            Navigation.NavigateTo("/login?mode=signin");
            return;
        }

        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", true);
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "A";
        }

        var initials = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]));

        return string.Concat(initials);
    }
}
