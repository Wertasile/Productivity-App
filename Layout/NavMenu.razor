@using MudBlazor

<MudDrawer @bind-Open="_open" Fixed="true" Elevation="1" Variant="DrawerVariant.Mini" OpenMiniOnHover="true"
           Breakpoint="Breakpoint.None">
    <MudNavMenu>
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Store">Dashboard</MudNavLink>
        <MudNavLink Href="/calendar" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.CalendarToday">Calendar</MudNavLink>
        <MudNavLink Href="/taskboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.CalendarViewWeek">TaskBoard</MudNavLink>
        <MudNavLink Href="/directory" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.FolderCopy">Directory</MudNavLink>
    </MudNavMenu>
</MudDrawer>


@code
{
    private bool _open = false;

    private void ToggleDrawer()
    {
        _open = !_open;
    }
}

