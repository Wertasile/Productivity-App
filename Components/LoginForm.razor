@inject AuthService AuthService
@inject AppSessionService AppSessionService
@inject NavigationManager Navigation

<EditForm Model="@loginModel" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label>Email</label>
        <InputText @bind-Value="loginModel.Email" placeholder="Email" />
    </div>

    <div>
        <label>Password</label>
        <InputText @bind-Value="loginModel.Password" type="password" placeholder="Password" />
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div>@errorMessage</div>
    }

    <button type="submit">Login</button>

    <button type="button" @onclick="() => OnSwitch.InvokeAsync(AuthState.Register)">New to EasyNote? Create an Account!</button>
    <button type="button" @onclick="ContinueWithoutAccountAsync">Continue without account</button>
</EditForm>

@code {
    [Parameter]
    public EventCallback<AuthState> OnSwitch { get; set; }

    private LoginModel loginModel = new();
    private string? errorMessage;

    private async Task HandleValidSubmit()
    {
        errorMessage = null;

        try
        {
            var response = await AuthService.LoginAsync(loginModel.Email, loginModel.Password);
            if (response == "Login successful.")
            {
                Navigation.NavigateTo("/dashboard");
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task ContinueWithoutAccountAsync()
    {
        await AppSessionService.ContinueAsGuestAsync();
        Navigation.NavigateTo("/dashboard");
    }

    public class LoginModel
    {
        [EditorRequired]
        public string Email { get; set; } = string.Empty;

        [EditorRequired]
        public string Password { get; set; } = string.Empty;
    }
}
