@{
    double cw = Width - LeftPad - RightPad;
    double ch = Height - TopPad - BottomPad;
    int n = Labels.Count;
    double slotW = n > 0 ? cw / n : cw;
    double yLabelCenter = TopPad + ch / 2.0;
}

<svg viewBox="0 0 @Width @Height" width="100%" style="max-width: 550px; display: block; overflow: visible;">
    <rect x="0" y="0" width="@Width" height="@Height" fill="#FBFAEC" style="border: 1px solid #000000;" />

    <!-- Y-axis title -->
    @* <text transform="rotate(-90)" x="@(-yLabelCenter)" y="14" text-anchor="middle" font-size="11" fill="#8c8c8c" letter-spacing="0.5">COUNT</text> *@

    <!-- Grid lines + Y-axis labels -->
    @for (int tick = 0; tick <= _niceMax; tick += _tickStep)
    {
        double gy = TopPad + (1.0 - (double)tick / _niceMax) * ch;
        <line x1="@LeftPad" y1="@gy" x2="@(Width - RightPad)" y2="@gy" stroke="#d6d2c4" stroke-width="1" />
        <svg:text x="@(LeftPad - 5)" y="@(gy + 4)" text-anchor="end" font-size="10" fill="#8c8c8c">@tick</svg:text>
    }

    <!-- Data lines -->
    <polyline points="@BuildPolyline(TaskCounts, cw, ch)"
              fill="none" stroke="#4c4fdc" stroke-width="4"
              stroke-linecap="round" stroke-linejoin="round" />
    <polyline points="@BuildPolyline(ReminderCounts, cw, ch)"
              fill="none" stroke="#e36ac8" stroke-width="4"
              stroke-linecap="round" stroke-linejoin="round" />

    <!-- X-axis baseline + tick marks + day labels -->
    <line x1="@LeftPad" y1="@(Height - BottomPad)" x2="@(Width - RightPad)" y2="@(Height - BottomPad)" stroke="#d6d2c4" stroke-width="1" />
    @for (int i = 0; i < n; i++)
    {
        double lx = LeftPad + (i + 0.5) * slotW;
        bool isToday = i == todayIndex;
        bool isHovered = i == _hoveredIndex;
        bool isActive = isToday || isHovered;
        string labelFill = isActive ? "#3a3728" : "#8c8c8c";
        string labelWeight = isActive ? "700" : "500";
        string indicatorFill = isHovered ? "#6f6a57" : "#7b7666";
        string indicatorOpacity = isHovered ? "0.62" : (isToday ? "0.38" : "0.0");

        <line x1="@lx" y1="@(Height - BottomPad)" x2="@lx" y2="@(Height - BottomPad + 6)" stroke="#8c8c8c" stroke-width="1" />
        <svg:text x="@lx" y="@(Height - BottomPad + 20)" text-anchor="middle" font-size="11" fill="@labelFill" font-weight="@labelWeight">@Labels[i]</svg:text>
        <rect x="@(lx - 18)" y="@(Height - BottomPad + 26)" width="36" height="4" rx="2"
              fill="@indicatorFill" fill-opacity="@indicatorOpacity"
              style="transition: fill-opacity 140ms ease, fill 140ms ease;" />
    }

    <!-- Hover hit areas (one column per day) -->
    @for (int i = 0; i < n; i++)
    {
        var idx = i;
        double hx = LeftPad + (i + 0.5) * slotW;
        double hitLeft = i == 0 ? LeftPad : hx - slotW / 2;
        double hitRight = i == n - 1 ? LeftPad + cw : hx + slotW / 2;
          <rect x="@hitLeft" y="@TopPad" width="@(hitRight - hitLeft)" height="@(ch + 36)"
              fill="transparent"
              @onmouseenter="() => _hoveredIndex = idx"
              @onmouseleave="() => _hoveredIndex = -1" />
    }

    <!-- Tooltip (always visible on today, overridden by hover) -->
    @{
        int activeTooltipIndex = (_hoveredIndex >= 0 && _hoveredIndex < n)
            ? _hoveredIndex
            : todayIndex;
    }
    @if (activeTooltipIndex >= 0 && activeTooltipIndex < n)
    {
        double tx = LeftPad + activeTooltipIndex * slotW;
        int tasks = (int)TaskCounts[activeTooltipIndex];
        int reminders = (int)ReminderCounts[activeTooltipIndex];

        double tyTask = TopPad + (1.0 - TaskCounts[activeTooltipIndex] / _niceMax) * ch;
        double tyRem  = TopPad + (1.0 - ReminderCounts[activeTooltipIndex] / _niceMax) * ch;
        double tyTop  = Math.Min(tyTask, tyRem);

        double tW = 150, tH = 68;
        double tX = Math.Max(LeftPad, Math.Min(tx - tW / 2, LeftPad + cw - tW));
        double tY = Math.Max(2, tyTop - tH - 12);
        double arrowX = Math.Clamp(tx, tX + 14, tX + tW - 14);

        <g pointer-events="none">
            <rect x="@tX" y="@tY" width="@tW" height="@tH" rx="8"
                  fill="#eeeaf8" stroke="#d8d4f0" stroke-width="1.5" />
            <polygon points="@(arrowX),@(tY+tH+8) @(arrowX-7),@(tY+tH) @(arrowX+7),@(tY+tH)"
                     fill="#eeeaf8" />
            <circle cx="@(tX+16)" cy="@(tY+22)" r="5" fill="#4c4fdc" />
            <text x="@(tX+28)" y="@(tY+27)" font-size="11" font-weight="700"
                  fill="#3a3728" letter-spacing="0.5">@tasks TASKS</text>
            <circle cx="@(tX+16)" cy="@(tY+46)" r="5" fill="#e36ac8" />
            <text x="@(tX+28)" y="@(tY+51)" font-size="11" font-weight="700"
                  fill="#3a3728" letter-spacing="0.5">@reminders REMINDERS</text>
        </g>
    }

</svg>

@code {
    [Parameter] public Dictionary<string, WeekItem> Data { get; set; } = new();
    [Parameter] public int Width { get; set; } = 550;
    [Parameter] public int Height { get; set; } = 300;

    private const double LeftPad   = 55;
    private const double RightPad  = 10;
    private const double TopPad    = 20;
    private const double BottomPad = 60;

    private List<double> TaskCounts     = new();
    private List<double> ReminderCounts = new();
    private List<string> Labels         = new();
    private int todayIndex    = -1;
    private int _niceMax      = 1;
    private int _tickStep     = 1;
    private int _hoveredIndex = -1;

    protected override void OnParametersSet()
    {
        var ordered = Data.OrderBy(d => d.Key).ToList();
        var today = DateTime.Today;
        todayIndex = ordered.FindIndex(d => DateTime.TryParse(d.Key, out var date) && date.Date == today);

        // If today's key is missing, default to the latest day so tooltip still shows by default.
        if (todayIndex < 0 && ordered.Count > 0)
        {
            todayIndex = ordered.Count - 1;
        }

        TaskCounts     = ordered.Select(d => (double)d.Value.Tasks.Count).ToList();
        ReminderCounts = ordered.Select(d => (double)d.Value.Reminders.Count).ToList();

        Labels = ordered.Select(d =>
        {
            var date = DateTime.Parse(d.Key);
            return date.ToString("ddd d").ToUpper();
        }).ToList();

        double tMax  = TaskCounts.Count > 0     ? TaskCounts.Max()     : 0;
        double rMax  = ReminderCounts.Count > 0 ? ReminderCounts.Max() : 0;
        double rawMax = Math.Max(Math.Max(tMax, rMax), 1);
        _niceMax  = GetNiceMax(rawMax);
        _tickStep = GetTickStep(_niceMax);
    }

    private static int GetNiceMax(double rawMax)
    {
        return (int)Math.Max(5.0, Math.Ceiling(rawMax));
    }

    private static int GetTickStep(int niceMax)
    {
        return Math.Max(1, niceMax / 10);
    }

    private string BuildPolyline(List<double> values, double cw, double ch)
    {
        if (values.Count == 0) return "";
        int cnt = values.Count;
        return string.Join(" ", values.Select((v, i) =>
        {
            double x = LeftPad + (i + 0.5) * (cw / Math.Max(cnt, 1));
            double y = TopPad + (1.0 - v / _niceMax) * ch;
            return $"{x:F1},{y:F1}";
        }));
    }

    public class DayData
    {
        public List<object> Tasks     { get; set; } = new();
        public List<object> Reminders { get; set; } = new();
    }
}