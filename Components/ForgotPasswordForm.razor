@inject AuthService AuthService

<div class="auth-form-container">
    <div class="auth-back-row">
        <button type="button" class="auth-link-muted" @onclick="() => OnSwitch.InvokeAsync(AuthState.Login)">
            ← Back to sign in
        </button>
    </div>

    <h2 class="auth-form-title">Reset password</h2>
    <p class="auth-form-subtitle">
        Enter your account email and we'll send you a reset code.
    </p>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="auth-error">
            <span>⚠</span>
            <span>@errorMessage</span>
        </div>
    }

    <EditForm Model="@forgotModel" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />

        <div class="auth-input-group" style="margin-bottom:1.5rem;">
            <label class="auth-input-label">Email</label>
            <InputText @bind-Value="forgotModel.Email"
                       class="auth-input"
                       placeholder="you@example.com"
                       type="email"
                       autocomplete="email" />
            <ValidationMessage For="() => forgotModel.Email" />
        </div>

        <button type="submit" class="auth-submit-btn" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="auth-spinner"></span>
            }
            Send Reset Code
        </button>
    </EditForm>

    <p class="auth-helper-text" style="margin-top:1.25rem;">
        Remembered it?&nbsp;
        <button type="button" class="auth-link" @onclick="() => OnSwitch.InvokeAsync(AuthState.Login)">Sign in</button>
    </p>
</div>

@code {
    [Parameter] public EventCallback<AuthState> OnSwitch { get; set; }
    [Parameter] public EventCallback<string> OnEmailCaptured { get; set; }

    private ForgotPasswordModel forgotModel = new();
    private string? errorMessage;
    private bool isLoading;

    private async Task HandleValidSubmit()
    {
        errorMessage = null;
        isLoading = true;
        try
        {
            var result = await AuthService.ForgotPasswordAsync(forgotModel.Email);
            if (result.Success)
            {
                await OnEmailCaptured.InvokeAsync(forgotModel.Email);
                await OnSwitch.InvokeAsync(AuthState.ResetPassword);
            }
            else
            {
                errorMessage = result.ErrorMessage ?? "Could not send reset code. Please try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;
    }
}
