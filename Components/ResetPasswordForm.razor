@inject AuthService AuthService

<div class="auth-form-container">
    <div class="auth-back-row">
        <button type="button" class="auth-link-muted" @onclick="() => OnSwitch.InvokeAsync(AuthState.Login)">
            ← Back to sign in
        </button>
    </div>

    <h2 class="auth-form-title">Set new password</h2>
    <p class="auth-form-subtitle">
        Enter the code we sent to <strong>@(string.IsNullOrWhiteSpace(Email) ? "your email" : Email)</strong>
        and choose a new password.
    </p>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="auth-error">
            <span>⚠</span>
            <span>@errorMessage</span>
        </div>
    }

    <EditForm Model="@resetModel" OnValidSubmit="@HandleValidSubmit">
        <DataAnnotationsValidator />

        @if (string.IsNullOrWhiteSpace(Email))
        {
            <div class="auth-input-group">
                <label class="auth-input-label">Email</label>
                <InputText @bind-Value="resetModel.Email"
                           class="auth-input"
                           placeholder="you@example.com"
                           type="email"
                           autocomplete="email" />
                <ValidationMessage For="() => resetModel.Email" />
            </div>
        }

        <div class="auth-input-group">
            <label class="auth-input-label">Reset Code</label>
            <InputText @bind-Value="resetModel.Code"
                       class="auth-input"
                       placeholder="6-digit code"
                       maxlength="6"
                       autocomplete="one-time-code"
                       style="letter-spacing:0.2em; font-size:1.1rem;" />
            <ValidationMessage For="() => resetModel.Code" />
        </div>

        <div class="auth-input-group">
            <label class="auth-input-label">New Password</label>
            <div class="auth-input-wrapper">
                <InputText @bind-Value="resetModel.NewPassword"
                           class="auth-input"
                           type="@(showPassword ? "text" : "password")"
                           placeholder="Create a new password"
                           autocomplete="new-password" />
                <button type="button" class="auth-input-eye" @onclick="() => showPassword = !showPassword" tabindex="-1">
                    @(showPassword ? "🙈" : "👁")
                </button>
            </div>
            <div class="auth-pw-hint">Min. 8 characters, one uppercase, one number.</div>
            <ValidationMessage For="() => resetModel.NewPassword" />
        </div>

        <div class="auth-input-group" style="margin-bottom:1.5rem;">
            <label class="auth-input-label">Confirm New Password</label>
            <div class="auth-input-wrapper">
                <InputText @bind-Value="resetModel.ConfirmPassword"
                           class="auth-input"
                           type="@(showConfirm ? "text" : "password")"
                           placeholder="Repeat new password"
                           autocomplete="new-password" />
                <button type="button" class="auth-input-eye" @onclick="() => showConfirm = !showConfirm" tabindex="-1">
                    @(showConfirm ? "🙈" : "👁")
                </button>
            </div>
            <ValidationMessage For="() => resetModel.ConfirmPassword" />
        </div>

        <button type="submit" class="primary-btn" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="auth-spinner"></span>
            }
            Reset Password
        </button>
    </EditForm>

    <p class="auth-helper-text" style="margin-top:1.25rem;">
        Need a new code?&nbsp;
        <button type="button" class="auth-link" @onclick="() => OnSwitch.InvokeAsync(AuthState.ForgotPassword)">
            Resend reset code
        </button>
    </p>
</div>

@code {
    [Parameter] public EventCallback<AuthState> OnSwitch { get; set; }
    [Parameter] public string? Email { get; set; }

    private ResetPasswordModel resetModel = new();
    private string? errorMessage;
    private bool isLoading;
    private bool showPassword;
    private bool showConfirm;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(Email))
            resetModel.Email = Email;
    }

    private async Task HandleValidSubmit()
    {
        if (resetModel.NewPassword != resetModel.ConfirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        errorMessage = null;
        isLoading = true;
        try
        {
            var result = await AuthService.ConfirmForgotPasswordAsync(resetModel.Email, resetModel.Code, resetModel.NewPassword);
            if (result.Success)
                await OnSwitch.InvokeAsync(AuthState.Login);
            else
                errorMessage = result.ErrorMessage ?? "Could not reset password. Please try again.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private class ResetPasswordModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Reset code is required.")]
        [MinLength(6, ErrorMessage = "Enter the full 6-digit code.")]
        public string Code { get; set; } = string.Empty;

        [Required(ErrorMessage = "New password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your new password.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
