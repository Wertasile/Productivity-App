@* @inject AuthService AuthService *@
@inject AppSessionService AppSessionService
@inject NavigationManager Navigation

<EditForm Model="@registerModel" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label>Username</label>
        <InputText @bind-Value="registerModel.Username" placeholder="Username" />
    </div>

    <div>
        <label>Password</label>
        <InputText @bind-Value="registerModel.Password" type="password" placeholder="Password" />
    </div>

    <button type="submit">Register</button>

    <button type="button" @onclick="() => OnSwitch.InvokeAsync(AuthState.Login)">Got an account, Login here!</button>
    <button type="button" @onclick="ContinueWithoutAccountAsync">Continue without account</button>
</EditForm>

@code {
    [Parameter]
    public EventCallback<AuthState> OnSwitch { get; set; }

    private RegisterModel registerModel = new();

    private Task HandleValidSubmit()
    {
        // var response = await AuthService.Register(registerModel.Username, registerModel.Email, registerModel.Password);
        // if (response.Success)
        // {
        //     Navigation.NavigateTo("/login");
        // }
        // else
        // {
        //     Console.WriteLine(response.ErrorMessage);
        // }
        return Task.CompletedTask;
    }

    private async Task ContinueWithoutAccountAsync()
    {
        await AppSessionService.ContinueAsGuestAsync();
        Navigation.NavigateTo("/dashboard");
    }

    public class RegisterModel
    {
        public string Username { get; set; } = string.Empty;

        public string Email { get; set; } = string.Empty;

        public string Password { get; set; } = string.Empty;
    }
}
