@using System.Net
@using System.Text.RegularExpressions
@inject NoteService NoteService

@* THIS IS THE NOTE EDITOR HOST, WITHIN WHICH THE TOOLBAR (EditorToolbar.razor) AND EDITOR SURFACE (TipTapEditor.razor) are embedded *@

<div class="note-editor-page">
    <div class="d-flex justify-content-between">
        <div class="note-editor-breadcrumb" aria-label="Breadcrumb">
            <span>@BreadcrumbRootLabel</span>
            <span class="note-editor-breadcrumb-sep">›</span>
            <span class="note-editor-breadcrumb-current">@BreadcrumbCurrentLabel</span>
        </div>

        <div class="d-flex align-items-center gap-1">

            @if (ShowBackButton)
            {
                <button type="button" class="primary-btn" @onclick="CloseEditor">Back</button>
            }
            
            <button type="button" class="primary-btn" @onclick="Save"
                    disabled="@isSaving">@saveButtonLabel</button>
        </div>
    </div>

    <div class="note-editor-toolbar-wrap">
        <EditorToolbar EditorId="@editorId" EditorState="@editorState" />
    </div>

    <div>

    </div>

    <div class="note-editor">
        @* <input type="text"
               placeholder="Title"
               value="@Note?.Title"
               @oninput="(e) => Note?.Title = e.Value.ToString()"
               class="min-w-full placeholder:text-[#9ca3af] placeholder:opacity-60 p-8"
               style="font-size: 36px; font-weight: bold; font-family: Manrope;" 
        /> *@
        <div class="top-line"></div>
        <div class="editor-top">
            <div class="mini-text">
                @if (noteModel.CreatedAt != null)
                {
                    <div>@noteModel.CreatedAt.ToString("yyyy MM dd")</div>
                }
                else
                {
                    <div>@DateTime.UtcNow.ToString("yyyy MM dd")</div>
                }

            </div>
            <input @bind="@noteModel.Title"
                   placeholder="Enter Title"/>
        </div>
        <TiptapEditor @key="editorId" EditorId="@editorId" InitialContent="@currentInitialHtml" OnChange="HandleChange"
                      OnStateChange="HandleStateChange" />
    </div>
</div>

@code {
    // editor Id to uniquely identify this editor instance, for multiple editors. Passed to the EditorToolbar and TiptapEditor components, which use it to coordinate actions and state specific to this editor instance.
    private string editorId = Guid.NewGuid().ToString();

    // content state from the editor, updated on every change, used to save the note content when the user clicks save
    private TiptapEditor.EditorContentChangedArgs? content;
    private TiptapEditor.EditorStateChangedArgs? editorState;

    // note model being edited, Note parameter passed in is cloned to this local model to allow editing 
    // without mutating the parent component's state until save is clicked. This also allows us to track whether we are editing an existing note (hasSavedNote) or creating a new one.
    private Note noteModel = new();
    private bool isSaving;
    private bool hasSavedNote;
    private string? loadedNoteId;
    private string? loadedFolderId;


    [Parameter] public Note? Note { get; set; }
    [Parameter] public string? FolderId { get; set; }
    [Parameter] public bool ShowBackButton { get; set; }
    [Parameter] public string BreadcrumbRootLabel { get; set; } = "Root";
    [Parameter] public string BreadcrumbCurrentLabel { get; set; } = "New Note";

    // event callbacks to notify parent component when a note is saved or when the editor is closed (e.g. back button clicked)
    [Parameter] public EventCallback<Note> OnSaved { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    // computed properties for button labels based on current state (isSaving, hasSavedNote) to provide user feedback in the UI
    private string saveButtonLabel => isSaving ? "Saving..." : hasSavedNote ? "Save Changes" : "Save";
    private string savePillLabel => hasSavedNote ? "Saved in folder" : "Draft";

    protected override void OnParametersSet()
    {
        var incomingNoteId = Note?.Id;
        var normalizedFolderId = NormalizeFolderId(FolderId);

        if (incomingNoteId == loadedNoteId && normalizedFolderId == loadedFolderId)
        {
            return;
        }

        loadedNoteId = incomingNoteId;
        loadedFolderId = normalizedFolderId;

        noteModel = Note is null ? CreateNewNote(normalizedFolderId) : CloneNote(Note);
        hasSavedNote = !string.IsNullOrWhiteSpace(noteModel.Id);
        currentInitialHtml = string.IsNullOrWhiteSpace(noteModel.Content) ? DefaultInitialHtml : noteModel.Content;
        BreadcrumbCurrentLabel = hasSavedNote ? noteModel.Title : "New Note";
        content = null;
        editorState = null;
        editorId = Guid.NewGuid().ToString();
    }

    private void HandleChange(TiptapEditor.EditorContentChangedArgs editorContent)
    {
        content = editorContent;
    }

    private void HandleStateChange(TiptapEditor.EditorStateChangedArgs state)
    {
        editorState = state;
        InvokeAsync(StateHasChanged);
    }

    private async Task Save()
    {
        if (isSaving)
        {
            return;
        }

        isSaving = true;

        try
        {
            noteModel.Content = content?.Html ?? currentInitialHtml;
            noteModel.Title = noteModel.Title ?? "Untitled Note";
            noteModel.FolderId = ResolveFolderForSave();
            noteModel.EntityType = "NOTE";

            if (hasSavedNote && !string.IsNullOrWhiteSpace(noteModel.Id))
            {
                noteModel = await NoteService.UpdateNote(noteModel);
            }
            else
            {
                var createdNote = await NoteService.CreateNote(noteModel);
                if (createdNote is not null)
                {
                    noteModel = createdNote;
                    hasSavedNote = true;
                }
            }

            if (hasSavedNote)
            {
                await OnSaved.InvokeAsync(noteModel);
            }
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task CloseEditor()
    {
        await OnClose.InvokeAsync();
    }


    private string? ResolveFolderForSave()
    {
        if (hasSavedNote && !string.IsNullOrWhiteSpace(noteModel.Id))
        {
            return NormalizeFolderId(noteModel.FolderId);
        }

        return NormalizeFolderId(FolderId);
    }

    private static string? NormalizeFolderId(string? folderId)
    {
        return string.IsNullOrWhiteSpace(folderId) || folderId == "ROOT" ? null : folderId;
    }

    private static Note CreateNewNote(string? folderId)
    {
        return new Note
        {
            FolderId = folderId,
            EntityType = "NOTE"
        };
    }

    private static Note CloneNote(Note source)
    {
        return new Note
        {
            Id = source.Id,
            UserId = source.UserId,
            FolderId = source.FolderId,
            EntityType = source.EntityType,
            Title = source.Title,
            Content = source.Content,
            CreatedAt = source.CreatedAt,
            UpdatedAt = source.UpdatedAt
        };
    }

    // private static string ExtractTitle(string html)
    // {
    //     if (string.IsNullOrWhiteSpace(html))
    //     {
    //         return "Untitled Note";
    //     }

    //     var headingMatch = Regex.Match(html, "<h1[^>]*>(.*?)</h1>", RegexOptions.IgnoreCase | RegexOptions.Singleline);
    //     var heading = headingMatch.Success ? SanitizeText(headingMatch.Groups[1].Value) : string.Empty;

    //     if (!string.IsNullOrWhiteSpace(heading))
    //     {
    //         return heading;
    //     }

    //     var plainText = SanitizeText(html);
    //     if (string.IsNullOrWhiteSpace(plainText))
    //     {
    //         return "Untitled Note";
    //     }

    //     return plainText.Length <= 64 ? plainText : $"{plainText[..64].TrimEnd()}...";
    // }



    private static string SanitizeText(string value)
    {
        var withoutTags = Regex.Replace(value, "<.*?>", " ");
        return WebUtility.HtmlDecode(withoutTags).Trim();
    }

    private string currentInitialHtml = DefaultInitialHtml;

    private const string DefaultInitialHtml =
        """
        <p class="note-date"></p>
        <h1 class="note-title"></h1>
        <p></p>
        """;
}
